generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  PASSENGER
  DRIVER
  ADMIN
}

enum TripStatus {
  REQUESTED
  DRIVER_ASSIGNED
  DRIVER_EN_ROUTE
  DRIVER_ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRIP_PAYMENT
  TRIP_EARNING
  REFUND
}

model User {
  id          String   @id @default(uuid())
  userId      String   @unique // e.g. p202621274 or d202621274
  fullName    String
  username    String   @unique
  email       String   @unique
  phone       String   @unique
  password    String
  dob         DateTime
  idNumber    String   @unique
  role        Role
  avatarUrl   String?
  rating      Float    @default(5.0)
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  wallet          Wallet?
  passengerTrips  Trip[]          @relation("PassengerTrips")
  driverTrips     Trip[]          @relation("DriverTrips")
  driverProfile   DriverProfile?
  ratingsGiven    Rating[]        @relation("RatingsGiven")
  ratingsReceived Rating[]        @relation("RatingsReceived")
  otpTokens       OtpToken[]
  refreshTokens   RefreshToken[]

  @@map("users")
}

model DriverProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleMake  String?
  vehicleModel String?
  vehiclePlate String?
  vehicleColor String?
  isClockedIn  Boolean  @default(false)
  isVerified   Boolean  @default(false)
  currentLat   Float?
  currentLng   Float?
  updatedAt    DateTime @updatedAt
  documents    DriverDocument[]

  @@map("driver_profiles")
}

model DriverDocument {
  id              String         @id @default(uuid())
  driverProfileId String
  driverProfile   DriverProfile  @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)
  docType         String         // LICENSE | PERMIT | REGISTRATION
  fileUrl         String
  status          DocumentStatus @default(PENDING)
  uploadedAt      DateTime       @default(now())
  reviewedAt      DateTime?
  reviewNote      String?

  @@unique([driverProfileId, docType])
  @@map("driver_documents")
}

model Wallet {
  id           String               @id @default(uuid())
  userId       String               @unique
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Decimal              @default(0.00) @db.Decimal(12, 2)
  updatedAt    DateTime             @updatedAt
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String          @id @default(uuid())
  walletId    String
  wallet      Wallet          @relation(fields: [walletId], references: [id])
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  tripId      String?
  createdAt   DateTime        @default(now())

  @@map("wallet_transactions")
}

model Trip {
  id              String     @id @default(uuid())
  passengerId     String
  passenger       User       @relation("PassengerTrips", fields: [passengerId], references: [id])
  driverId        String?
  driver          User?      @relation("DriverTrips", fields: [driverId], references: [id])
  status          TripStatus @default(REQUESTED)
  pickupAddress   String
  pickupLat       Float
  pickupLng       Float
  dropoffAddress  String
  dropoffLat      Float
  dropoffLng      Float
  seats           Int        @default(1)
  distanceKm      Float?
  durationMin     Float?
  totalPrice      Decimal?   @db.Decimal(10, 2)
  driverEarning   Decimal?   @db.Decimal(10, 2)  // 80%
  systemCommission Decimal?  @db.Decimal(10, 2)  // 20%
  cancelledBy     String?    // userId of who cancelled
  cancelReason    String?
  cancelledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  locations TripLocation[]
  ratings   Rating[]

  @@map("trips")
}

model TripLocation {
  id        String   @id @default(uuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  recordedAt DateTime @default(now())

  @@map("trip_locations")
}

model Rating {
  id         String   @id @default(uuid())
  tripId     String
  trip       Trip     @relation(fields: [tripId], references: [id])
  giverId    String
  giver      User     @relation("RatingsGiven", fields: [giverId], references: [id])
  receiverId String
  receiver   User     @relation("RatingsReceived", fields: [receiverId], references: [id])
  score      Int      // 1-5
  review     String?
  createdAt  DateTime @default(now())

  @@unique([tripId, giverId])
  @@map("ratings")
}

model OtpToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_tokens")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}
